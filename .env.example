# ============================================
# Touring Content Updater - Environment Vars
# ============================================
# Kopieer dit bestand naar .env.local voor lokale dev.
# Voeg dezelfde variabelen toe in Vercel → Settings → Environment Variables.

# --- Claude API (VERPLICHT) ---
# Haal op via https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# --- Modellen per rol (allemaal OPTIONEEL) ---
# De tool gebruikt slimme defaults die snelheid en kwaliteit balanceren:
#   analyze  → claude-haiku-4-5-20251001  (snel, structuurwerk)
#   rewrite  → claude-sonnet-4-6          (creatieve copy, kwaliteit telt)
#   editor   → claude-sonnet-4-6          (AI-slop oordeelsvermogen)
#
# Je kan elke rol afzonderlijk overschrijven als je meer/minder kwaliteit wil:
# ANTHROPIC_MODEL_ANALYZE=claude-sonnet-4-6
# ANTHROPIC_MODEL_REWRITE=claude-opus-4-6
# ANTHROPIC_MODEL_EDITOR=claude-opus-4-6
#
# Globale fallback (alleen voor niet-gerolde calls). Niet vereist.
ANTHROPIC_MODEL=

# --- Ahrefs API (OPTIONEEL) ---
# Haal op via Ahrefs → API → Access Tokens.
# Als deze ontbreekt gebruikt de tool een fallback zonder echte keyword-data.
AHREFS_API_TOKEN=

# Locatie voor Ahrefs-calls. BE = België. Zie Ahrefs docs voor country codes.
AHREFS_COUNTRY=be

# --- Toegangscontrole ---
# Wachtwoord voor de hele app (middleware.ts).
# Kies iets sterks, je geeft het door aan wie toegang krijgt.
APP_PASSWORD=changeme

# Cookiesecret voor signed auth-cookies. Genereer met:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# --- Deploy ---
# Next.js draait op deze URL in productie. Voor Vercel: automatisch ingesteld.
NEXT_PUBLIC_APP_URL=http://localhost:3000
